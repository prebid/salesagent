# AdCP Sales Agent - Environment Configuration (example)
# =======================================================
#
# Copy this file to .env and fill in real values:  cp .env.example .env
#
# Quick Start: `docker compose up` boots the full stack in test mode — no values
# below are required for local development. Fill these in only for production.
#
# This file is the canonical minimal reference. The longer annotated template
# (all optional settings with prose explanations) lives at .env.template.

# ============================================
# [REQUIRED in production] Session Secret
# ============================================
# Signs the admin session cookie. MUST be >= 32 characters. The app raises at
# startup if this is missing or too short (see Invariant: "Admin FastAPI
# startup fails fast on weak session secret").
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=

# ============================================
# [REQUIRED] Database
# ============================================
# Production exclusively uses PostgreSQL — SQLite is not supported.
DATABASE_URL=postgresql://user:pass@localhost:5432/salesagent

# TCP-handshake cap for the pre-uvicorn DatabaseConnection probe + the
# SQLAlchemy engine connect_args (seconds). Default: 10.
DATABASE_CONNECT_TIMEOUT=10

# ============================================
# [OPTIONAL] Super Admin Access
# ============================================
# In test mode (default), use the test login buttons instead.
# For production, set your email(s) or domain(s):
# SUPER_ADMIN_EMAILS=your-email@example.com
# SUPER_ADMIN_DOMAINS=example.com

# ============================================
# [OPTIONAL] Authentication
# ============================================
# Test mode is enabled by default — no OAuth needed for quick start.
# Pre-configured test accounts: test_super_admin@example.com / test123
#
# For production, set ADCP_AUTH_TEST_MODE=false and configure OAuth below.
# ADCP_AUTH_TEST_MODE=false

# --------------------------------------------
# OAuth Configuration
# --------------------------------------------
# Works with any OIDC provider. See .env.template for full discovery URLs.
# OAUTH_DISCOVERY_URL=
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# OAUTH_SCOPES=openid email profile

# ============================================
# [OPTIONAL] Google Ad Manager Integration
# ============================================
# Required only if using GAM adapter with OAuth authentication.
# GAM_OAUTH_CLIENT_ID=
# GAM_OAUTH_CLIENT_SECRET=

# ============================================
# [OPTIONAL] Control-Plane API Keys
# ============================================
# Generate with: python -c "import secrets; print(f'sk-{secrets.token_urlsafe(32)}')"
# TENANT_MANAGEMENT_API_KEY=
# SYNC_API_KEY=

# ============================================
# [AUTO-GENERATED] Encryption
# ============================================
# Generated by `make setup` / `scripts/setup-dev.py` if not already set.
# For production: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# ============================================
# [OPTIONAL] Advanced Settings
# ============================================
# Schema validation strictness: 'development' (default, strict) or 'production' (lenient).
# ENVIRONMENT=production

# Demo tenant creation (default: false). Set true for local evaluation.
# CREATE_DEMO_TENANT=true

# Approximated API key — external-domain routing; required only in prod.
# APPROXIMATED_API_KEY=
